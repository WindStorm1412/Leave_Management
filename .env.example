# Website
HOST=127.0.0.1
PORT=3000

# MySQL Server
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=leave_management
DB_USER=root
DB_PASSWORD=
DB_CONNECTION_LIMIT=10

# Đặt thành false nếu tài khoản MySQL không có quyền CREATE DATABASE.
# Khi đó hãy import database.sql trước khi chạy website.
DB_AUTO_CREATE=true

# Tự thêm dữ liệu demo khi bảng users đang trống.
DB_AUTO_SEED=true
